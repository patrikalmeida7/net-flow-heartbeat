# =============================================================
# NOC Agent — variáveis de ambiente do docker-compose
# Copie pra .env e preencha. NÃO comite .env real.
# =============================================================

# ---------- Imagem ----------
# Repo da imagem no GHCR (gerado pelo CI .github/workflows/agent-image.yml)
# Ajuste se o repo do GitHub for outro.
IMAGE_REF=ghcr.io/patrikalmeida7/net-flow-heartbeat-agent
# Tag pra rodar em produção. Watchtower observa "latest" automaticamente.
# Pra travar versão: use "v1.2.0" e o Watchtower NÃO atualiza.
IMAGE_TAG=latest

# ---------- VPN (opcional) ----------
# Token do agente (Admin → Agentes no painel). Deixe vazio se
# não for usar o loop de VPN nem provisionamento de clientes.
VPN_AGENT_TOKEN=
VPN_SYNC_URL=https://rzubqfexhptentnkjcaq.supabase.co/functions/v1/vpn-agent-sync

# ---------- Provisionamento de clientes VPN (opcional) ----------
# Quando ativo, o agente busca clientes pendentes a cada 15s e
# executa `noc-add-client <nome> <ip>` na própria VPS.
CLIENTS_SYNC_URL=https://rzubqfexhptentnkjcaq.supabase.co/functions/v1/vpn-clients-agent-sync
# Comando a executar (path absoluto recomendado em produção)
NOC_ADD_CLIENT_CMD=noc-add-client
# Onde o noc-add-client salva o .conf gerado. {nome} é substituído.
NOC_CLIENT_CONF_PATH=/etc/wireguard/clients/{nome}.conf
# Intervalos
CLIENTS_POLL_INTERVAL_MS=15000
CLIENTS_CMD_TIMEOUT_MS=60000

# ---------- Sistema ----------
TZ=America/Sao_Paulo
